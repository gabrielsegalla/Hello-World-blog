# --- Banco de dados (Supabase Postgres) ---
# Supabase Dashboard → Project Settings → Database → Connection string
# Use a "Direct connection" (porta 5432) — a integração Supabase na Vercel
# injeta isso automaticamente como POSTGRES_URL_NON_POOLING.
POSTGRES_URL_NON_POOLING="postgresql://postgres:[senha]@db.[ref].supabase.co:5432/postgres"

# Opcional: se quiser usar pooler no futuro (melhor para alto tráfego serverless),
# adicione também DATABASE_URL com a Transaction pooler (porta 6543) e ajuste o schema.
# DATABASE_URL="postgresql://postgres.[ref]:[senha]@aws-0-[regiao].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# --- Autenticação ---
JWT_SECRET="mude-isso-em-producao-use-string-longa-aleatoria"

# --- Admin inicial (usado no seed) ---
ADMIN_EMAIL="gabriel@segalla.dev"
ADMIN_PASSWORD="sua-senha-segura"

# --- Email (Resend) ---
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxx"
EMAIL_FROM="Gabriel Segalla <newsletter@segalla.dev>"

# --- Supabase Storage (upload de capas no admin) ---
NEXT_PUBLIC_SUPABASE_URL="https://[ref].supabase.co"
SUPABASE_SERVICE_ROLE_KEY="sua-service-role-key"
SUPABASE_STORAGE_BUCKET="covers"

# --- URLs ---
NEXT_PUBLIC_SITE_URL="https://segalla.dev"
NEXT_PUBLIC_KIWIFY_URL="https://pay.kiwify.com.br/SEU-LINK"
