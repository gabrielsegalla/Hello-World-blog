# --- Banco de dados (Supabase Postgres) ---
# Supabase Dashboard → Project Settings → Database → Connection string
# Use a "Direct connection" (porta 5432) — a integração Supabase na Vercel
# injeta isso automaticamente como POSTGRES_URL_NON_POOLING.
POSTGRES_URL_NON_POOLING="postgresql://postgres:[senha]@db.[ref].supabase.co:5432/postgres"

# Opcional: se quiser usar pooler no futuro (melhor para alto tráfego serverless),
# adicione também DATABASE_URL com a Transaction pooler (porta 6543) e ajuste o schema.
# DATABASE_URL="postgresql://postgres.[ref]:[senha]@aws-0-[regiao].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# --- Autenticação ---
JWT_SECRET="mude-isso-em-producao-use-string-longa-aleatoria"

# --- Admin inicial (usado no seed) ---
ADMIN_EMAIL="gabriel@segalla.dev"
ADMIN_PASSWORD="sua-senha-segura"

# --- Email (Resend) ---
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxx"
EMAIL_FROM="Gabriel Segalla <newsletter@segalla.dev>"

# --- Upload de imagens ---
# local = salva em public/uploads/ (dev, sem bucket Supabase)
# supabase = bucket remoto (produção)
UPLOAD_STORAGE="local"
# UPLOAD_LOCAL_DIR="public/uploads"
# NEXT_PUBLIC_SUPABASE_URL="https://[ref].supabase.co"
# SUPABASE_SERVICE_ROLE_KEY="sua-service-role-key"
# SUPABASE_STORAGE_BUCKET="covers"

# --- Automação (skills segalla-blog-post / article-writer) ---
BLOG_URL="https://hello-world-blog-xi.vercel.app"
BLOG_ADMIN_EMAIL="gabriel@segalla.dev"
BLOG_ADMIN_PASSWORD="sua-senha-segura"

# --- Meta / Instagram Graph API ---
# https://developers.facebook.com/apps/
META_APP_ID=""
META_APP_SECRET=""
META_GRAPH_VERSION="v21.0"
META_REDIRECT_URI="https://segalla.dev/api/instagram/callback"

# --- OpenAI (artigos + carrosséis Instagram) ---
# https://platform.openai.com/api-keys
OPENAI_API_KEY="sk-..."
OPENAI_TEXT_MODEL="gpt-4o-mini"
OPENAI_IMAGE_MODEL="gpt-image-1"
OPENAI_IMAGE_SIZE="1024x1024"

# --- Imagens: API ou ChatGPT web (gambiarra local) ---
# openai-api = padrão (funciona na Vercel)
# chatgpt-web = usa sua assinatura Plus via Playwright (só local)
IMAGE_PROVIDER="openai-api"
CHATGPT_USER_DATA_DIR=".chatgpt/browser-profile"
CHATGPT_HEADLESS="true"
# CHATGPT_HEADED_FALLBACK="true"
CHATGPT_EMAIL="seu@gmail.com"
CHATGPT_PASSWORDS="senha1,senha2"
# ou uma senha: CHATGPT_PASSWORD="sua-senha"
# CHATGPT_BROWSER_CHANNEL="chrome"
# CHATGPT_IMAGE_TIMEOUT_MS="240000"

# --- Cron (agendamento Instagram na Vercel) ---
CRON_SECRET="string-longa-aleatoria-para-cron"

# --- URLs ---
NEXT_PUBLIC_SITE_URL="https://segalla.dev"
NEXT_PUBLIC_KIWIFY_URL="https://pay.kiwify.com.br/SEU-LINK"
