# --- Banco de dados (Vercel Postgres) ---
# Em produção, a Vercel injeta automaticamente quando você conecta o Storage.
# Pra dev local, copie os valores do dashboard da Vercel (Storage > .env.local).
POSTGRES_PRISMA_URL="postgres://...?pgbouncer=true&connect_timeout=15"
POSTGRES_URL_NON_POOLING="postgres://..."

# --- Autenticação ---
# Use uma string aleatória longa em produção (mín. 32 chars).
# Gere com: openssl rand -base64 48
JWT_SECRET="mude-isso-em-producao-use-string-longa-aleatoria"

# --- Admin inicial (usado no seed) ---
ADMIN_EMAIL="gabriel@segalla.dev"
ADMIN_PASSWORD="sua-senha-segura"

# --- Email (Resend) ---
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxx"
EMAIL_FROM="Gabriel Segalla <newsletter@segalla.dev>"

# --- URLs ---
NEXT_PUBLIC_SITE_URL="https://segalla.dev"
NEXT_PUBLIC_KIWIFY_URL="https://pay.kiwify.com.br/SEU-LINK"
